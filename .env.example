# Runtime data provider
# Keep "supabase" while the legacy provider is active.
# Phase 2-3 will switch production to "google-drive" after Google auth/storage are wired.
VITE_DATA_PROVIDER="supabase"
DATA_PROVIDER="supabase"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public application URL.
APP_URL="MY_APP_URL"

# Legacy Supabase configuration.
# Required only when DATA_PROVIDER / VITE_DATA_PROVIDER is "supabase".
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Google provider placeholders (implemented in Phase 2-3).
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_ALLOWED_EMAIL="your-authorized-email@example.com"
GOOGLE_DRIVE_ROOT_FOLDER_ID="your-finance-buddy-folder-id"
SESSION_SECRET="replace-with-a-long-random-secret"
